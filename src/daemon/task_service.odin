package main

import "core:fmt"
import "core:strings"

Task_Service_Result :: struct {
	ok: bool,
	status_code: int,
	message: string,
}

task_service_create_task :: proc(cmd: Task_Create_Command) -> Task_Service_Result {
	if cmd.task_id != "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"task_id is generated by daemon; omit task_id on create"}`}
	if cmd.title == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"task create requires title"}`}
	task_id := task_generate_id()
	status := cmd.status
	if status == "" do status = "pending"
	if !task_status_allowed(status) do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"invalid task status"}`}
	if task_status_active_name(status) {
		if dep_blockers := task_dependency_blocking_ids(cmd.depends_on); dep_blockers != "" do return task_gating_error("dependency", "unmet task dependencies", dep_blockers)
		if cmd.assignee_agent_instance_id != "" {
			if active_blocker := task_active_slot_blocker(cmd.assignee_agent_instance_id, ""); active_blocker != "" do return task_gating_error("assignee_active_task", "assignee already has an active task", active_blocker)
		}
	}
	chain_id := cmd.chain_id
	created_chain := false
	if chain_id == "" && !cmd.standalone {
		chain_id = task_chain_id_for_root(task_id)
		chain_event := Task_Event{kind = .Chain_Created, chain_id = chain_id, title = cmd.title, description = cmd.description, status = "active", coordinator_agent_instance_id = cmd.coordinator_agent_instance_id, default_reviewer_agent_instance_id = cmd.reviewer_agent_instance_id, author_agent_instance_id = cmd.author_agent_instance_id}
		if !task_store_append_event(chain_event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task chain create failed"}`}
		created_chain = true
	}
	priority := cmd.priority
	if priority == "" do priority = "normal"
	event := Task_Event{kind = .Task_Created, task_id = task_id, chain_id = chain_id, title = cmd.title, description = cmd.description, acceptance_criteria = cmd.acceptance_criteria, priority = priority, status = status, assignee_agent_instance_id = cmd.assignee_agent_instance_id, reviewer_agent_instance_id = cmd.reviewer_agent_instance_id, coordinator_agent_instance_id = cmd.coordinator_agent_instance_id, depends_on = cmd.depends_on, created_by = cmd.created_by, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task create failed"}`}
	task_notify_event(event)
	builder := strings.builder_make()
	strings.write_string(&builder, `{"ok":true,"task_id":"`)
	json_write_string(&builder, task_id)
	strings.write_string(&builder, `","chain_id":"`)
	json_write_string(&builder, chain_id)
	strings.write_string(&builder, `","root_task_id":"`)
	json_write_string(&builder, task_root_id_for_response(chain_id, task_id, created_chain))
	strings.write_string(&builder, `","created_chain":`)
	strings.write_string(&builder, "true" if created_chain else "false")
	strings.write_string(&builder, `,"standalone":`)
	strings.write_string(&builder, "true" if cmd.standalone else "false")
	strings.write_string(&builder, `}`)
	return Task_Service_Result{ok = true, status_code = 200, message = strings.to_string(builder)}
}

task_chain_id_for_root :: proc(task_id: string) -> string {
	if strings.has_prefix(task_id, "task-") do return fmt.tprintf("chain-%s", task_id[len("task-"):])
	return fmt.tprintf("chain-%s", task_id)
}

task_root_id_for_response :: proc(chain_id, task_id: string, created_chain: bool) -> string {
	if chain_id == "" do return ""
	if created_chain do return task_id
	for i in 0..<task_state_count {
		state := task_states[i]
		if state.chain_id == chain_id do return state.task_id
	}
	return ""
}

task_generate_id :: proc() -> string {
	base := router_now_unix_ms()
	for i in 0..<1000 {
		candidate := fmt.tprintf("task-%x", base + i64(i))
		if !task_id_exists(candidate) do return candidate
	}
	return fmt.tprintf("task-%x", router_now_unix_ms())
}

task_id_exists :: proc(task_id: string) -> bool {
	for i in 0..<task_state_count {
		if task_states[i].task_id == task_id do return true
	}
	return false
}

task_existing_state_index :: proc(task_id, chain_id: string) -> (int, bool) {
	for i in 0..<task_state_count {
		if task_states[i].task_id == task_id && (chain_id == "" || task_states[i].chain_id == chain_id) do return i, true
	}
	return -1, false
}

task_existing_chain_index :: proc(chain_id: string) -> (int, bool) {
	for i in 0..<task_chain_count {
		if task_chains[i].chain_id == chain_id do return i, true
	}
	return -1, false
}

task_generate_chain_id :: proc() -> string {
	base := router_now_unix_ms()
	for i in 0..<1000 {
		candidate := fmt.tprintf("chain-%x", base + i64(i))
		if !task_chain_id_exists(candidate) do return candidate
	}
	return fmt.tprintf("chain-%x", router_now_unix_ms())
}

task_chain_id_exists :: proc(chain_id: string) -> bool {
	for i in 0..<task_chain_count {
		if task_chains[i].chain_id == chain_id do return true
	}
	return false
}

task_service_create_chain :: proc(cmd: Task_Chain_Create_Command) -> Task_Service_Result {
	if cmd.title == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"chain create requires title"}`}
	chain_id := cmd.chain_id
	if chain_id == "" do chain_id = task_generate_chain_id()
	status := cmd.status
	if status == "" do status = "active"
	event := Task_Event{kind = .Chain_Created, chain_id = chain_id, title = cmd.title, description = cmd.description, status = status, coordinator_agent_instance_id = cmd.coordinator_agent_instance_id, default_reviewer_agent_instance_id = cmd.default_reviewer_agent_instance_id, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append chain create failed"}`}
	task_notify_event(event)
	builder := strings.builder_make()
	strings.write_string(&builder, `{"ok":true,"chain_id":"`); json_write_string(&builder, chain_id)
	strings.write_string(&builder, `","status":"`); json_write_string(&builder, status)
	strings.write_string(&builder, `"}`)
	return Task_Service_Result{ok = true, status_code = 200, message = strings.to_string(builder)}
}

task_service_comment :: proc(task_id, chain_id, body, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_comment_command(Task_Comment_Command{task_id = task_id, chain_id = chain_id, body = body, author_agent_instance_id = author_agent_instance_id})
}

task_service_comment_command :: proc(cmd: Task_Comment_Command) -> Task_Service_Result {
	if cmd.task_id == "" || cmd.body == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"task comment requires task_id and body"}`}
	event := Task_Event{kind = .Task_Comment, task_id = cmd.task_id, chain_id = cmd.chain_id, body = cmd.body, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task comment failed"}`}
	task_notify_event(event)
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_service_assign :: proc(task_id, chain_id, agent_instance_id, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_assign_command(Task_Assign_Command{task_id = task_id, chain_id = chain_id, agent_instance_id = agent_instance_id, author_agent_instance_id = author_agent_instance_id})
}

task_service_assign_command :: proc(cmd: Task_Assign_Command) -> Task_Service_Result {
	if cmd.task_id == "" || cmd.agent_instance_id == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"task assignment requires task_id and agent_instance_id"}`}
	idx, found := task_existing_state_index(cmd.task_id, cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"task not found"}`}
	state := task_states[idx]
	if task_status_active_for_assignee(state) {
		if active_blocker := task_active_slot_blocker(cmd.agent_instance_id, state.task_id); active_blocker != "" do return task_gating_error("assignee_active_task", "assignee already has an active task", active_blocker)
	}
	event := Task_Event{kind = .Task_Assigned, task_id = cmd.task_id, chain_id = cmd.chain_id, agent_instance_id = cmd.agent_instance_id, role = "assignee", author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task assignment failed"}`}
	task_notify_event(event)
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_service_add_participant :: proc(task_id, chain_id, agent_instance_id, role, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_participant_command(Task_Participant_Command{task_id = task_id, chain_id = chain_id, agent_instance_id = agent_instance_id, role = role, author_agent_instance_id = author_agent_instance_id})
}

task_service_participant_command :: proc(cmd: Task_Participant_Command) -> Task_Service_Result {
	if cmd.task_id == "" || cmd.agent_instance_id == "" || cmd.role == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"participant requires task_id, agent_instance_id, and role"}`}
	event := Task_Event{kind = .Task_Participant_Added, task_id = cmd.task_id, chain_id = cmd.chain_id, agent_instance_id = cmd.agent_instance_id, role = cmd.role, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append participant failed"}`}
	task_notify_event(event)
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_service_set_status :: proc(task_id, chain_id, status, body, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_status_command(Task_Status_Command{task_id = task_id, chain_id = chain_id, status = status, body = body, author_agent_instance_id = author_agent_instance_id})
}

task_service_status_command :: proc(cmd: Task_Status_Command) -> Task_Service_Result {
	if cmd.task_id == "" || cmd.status == "" || strings.trim_space(cmd.body) == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"task status change requires task_id, status, and non-empty body"}`}
	if !task_status_allowed(cmd.status) do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"invalid task status"}`}
	idx, found := task_existing_state_index(cmd.task_id, cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"task not found"}`}
	state := task_states[idx]
	if !task_status_change_authorized(state, cmd.status, cmd.author_agent_instance_id) do return Task_Service_Result{ok = false, status_code = 403, message = `{"ok":false,"message":"not authorized for task status transition"}`}
	if task_status_active_name(cmd.status) {
		if dep_blockers := task_dependency_blocking_ids(state.depends_on); dep_blockers != "" do return task_gating_error("dependency", "unmet task dependencies", dep_blockers)
		assignee := state.assignee_agent_instance_id
		if assignee != "" {
			if active_blocker := task_active_slot_blocker(assignee, state.task_id); active_blocker != "" do return task_gating_error("assignee_active_task", "assignee already has an active task", active_blocker)
		}
	}
	event := Task_Event{kind = .Task_Status_Changed, task_id = cmd.task_id, chain_id = cmd.chain_id, status = cmd.status, body = cmd.body, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task status failed"}`}
	task_notify_event(event)
	task_recompute_promotions(cmd.author_agent_instance_id)
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_service_review :: proc(task_id, chain_id, result, comment, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_review_command(Task_Review_Command{task_id = task_id, chain_id = chain_id, result = result, comment = comment, author_agent_instance_id = author_agent_instance_id})
}

task_service_review_command :: proc(cmd: Task_Review_Command) -> Task_Service_Result {
	if cmd.task_id == "" || cmd.result == "" || strings.trim_space(cmd.comment) == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"review requires task_id, result, and non-empty comment"}`}
	status := ""
	switch cmd.result {
	case "approved": status = "approved"
	case "needs_improvements": status = "needs_improvements"
	case "rejected": status = "rejected"
	case: return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"review result must be approved, needs_improvements, or rejected"}`}
	}
	idx, found := task_existing_state_index(cmd.task_id, cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"task not found"}`}
	state := task_states[idx]
	if !task_actor_has_role(state, cmd.author_agent_instance_id, "reviewer") && !task_actor_can_override(state, cmd.author_agent_instance_id) do return Task_Service_Result{ok = false, status_code = 403, message = `{"ok":false,"message":"not authorized for task review"}`}
	event := Task_Event{kind = .Task_Review_Submitted, task_id = cmd.task_id, chain_id = cmd.chain_id, status = status, body = cmd.comment, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append review failed"}`}
	task_notify_event(event)
	task_recompute_promotions(cmd.author_agent_instance_id)
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_status_allowed :: proc(status: string) -> bool {
	switch status {
	case "pending", "ready", "claimed", "working", "in_progress", "open", "blocked", "review", "needs_review", "needs_improvements", "approved", "rejected", "done", "validated", "archived", "cancelled":
		return true
	case:
		return false
	}
}

task_status_active_name :: proc(status: string) -> bool {
	switch status {
	case "ready", "claimed", "working", "in_progress", "open", "review", "needs_review", "needs_improvements", "approved", "rejected", "done":
		return true
	case:
		return false
	}
}

task_gating_error :: proc(error_kind, message, blocking_task_ids: string) -> Task_Service_Result {
	builder := strings.builder_make()
	strings.write_string(&builder, `{"ok":false,"message":"`); json_write_string(&builder, message)
	strings.write_string(&builder, `","error":"`); json_write_string(&builder, error_kind)
	strings.write_string(&builder, `","blocking_task_ids":[`)
	ids := strings.split(blocking_task_ids, ",")
	first := true
	for id_raw in ids {
		id := strings.trim_space(id_raw)
		if id == "" do continue
		if !first do strings.write_string(&builder, `,`)
		first = false
		strings.write_string(&builder, `"`); json_write_string(&builder, id); strings.write_string(&builder, `"`)
	}
	strings.write_string(&builder, `]}`)
	return Task_Service_Result{ok = false, status_code = 409, message = strings.to_string(builder)}
}

task_actor_is_user :: proc(actor: string) -> bool {
	return actor != "" && !registry_agent_exists(actor)
}

task_actor_has_role :: proc(state: Task_State, actor, role: string) -> bool {
	if actor == "" do return false
	switch role {
	case "assignee": if state.assignee_agent_instance_id == actor do return true
	case "reviewer": if state.reviewer_agent_instance_id == actor do return true
	case "coordinator": if state.coordinator_agent_instance_id == actor do return true
	case:
	}
	for i in 0..<task_participant_count {
		p := task_participants[i]
		if p.role != role || p.agent_instance_id != actor do continue
		if p.task_id != state.task_id && (state.chain_id == "" || p.chain_id != state.chain_id) do continue
		return true
	}
	return false
}

task_actor_can_override :: proc(state: Task_State, actor: string) -> bool {
	return task_actor_is_user(actor) || task_actor_has_role(state, actor, "coordinator")
}

task_status_change_authorized :: proc(state: Task_State, next_status, actor: string) -> bool {
	if task_actor_can_override(state, actor) do return true
	switch next_status {
	case "pending", "ready", "claimed", "working", "in_progress", "open", "blocked", "review", "done":
		return task_actor_has_role(state, actor, "assignee")
	case "needs_review", "needs_improvements", "approved", "rejected", "validated":
		return task_actor_has_role(state, actor, "reviewer")
	case "archived", "cancelled":
		return false
	case:
		return false
	}
}

task_service_update_chain :: proc(cmd: Task_Chain_Update_Command) -> Task_Service_Result {
	if cmd.chain_id == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"chain update requires chain_id"}`}
	chain_idx, found := task_existing_chain_index(cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"chain not found"}`}
	chain := task_chains[chain_idx]
	title := cmd.title
	if title == "" do title = chain.title
	description := cmd.description
	if description == "" do description = chain.description
	coordinator := cmd.coordinator_agent_instance_id
	if coordinator == "" do coordinator = chain.coordinator_agent_instance_id
	default_reviewer := cmd.default_reviewer_agent_instance_id
	if default_reviewer == "" do default_reviewer = chain.default_reviewer_agent_instance_id
	event := Task_Event{kind = .Chain_Metadata_Updated, chain_id = cmd.chain_id, title = title, description = description, coordinator_agent_instance_id = coordinator, default_reviewer_agent_instance_id = default_reviewer, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append chain update failed"}`}
	task_notify_event(event)
	if cmd.final_summary != "" {
		summary_event := Task_Event{kind = .Chain_Final_Summary_Set, chain_id = cmd.chain_id, body = cmd.final_summary, author_agent_instance_id = cmd.author_agent_instance_id}
		if !task_store_append_event(summary_event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append chain summary failed"}`}
		task_notify_event(summary_event)
	}
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true}`}
}

task_service_nudge :: proc(task_id, chain_id, body, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_nudge_command(Task_Nudge_Command{task_id = task_id, chain_id = chain_id, body = body, author_agent_instance_id = author_agent_instance_id})
}

task_service_nudge_command :: proc(cmd: Task_Nudge_Command) -> Task_Service_Result {
	if cmd.task_id == "" || strings.trim_space(cmd.body) == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"nudge requires task_id and non-empty body"}`}
	idx, found := task_existing_state_index(cmd.task_id, cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"task not found"}`}
	state := task_states[idx]
	status := state.status
	if task_status_terminal_for_nudge(status) do return Task_Service_Result{ok = false, status_code = 409, message = `{"ok":false,"message":"terminal task cannot be nudged"}`}
	target := task_nudge_target_for_status(state, status)
	if target == "" do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"no nudge target for task status"}`}
	event := Task_Event{kind = .Task_Nudged, task_id = state.task_id, chain_id = state.chain_id, status = status, body = cmd.body, agent_instance_id = target, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append task nudge failed"}`}
	sent := task_notify_event(event)
	builder := strings.builder_make()
	strings.write_string(&builder, `{"ok":true,"target_agent_instance_id":"`); json_write_string(&builder, target)
	strings.write_string(&builder, `","sent":`); strings.write_string(&builder, "true" if sent else "false")
	strings.write_string(&builder, `}`)
	return Task_Service_Result{ok = true, status_code = 200, message = strings.to_string(builder)}
}

task_status_terminal_for_nudge :: proc(status: string) -> bool {
	return status == "done" || status == "archived" || status == "cancelled"
}

task_nudge_target_for_status :: proc(state: Task_State, status: string) -> string {
	switch status {
	case "ready", "working", "claimed", "in_progress", "open", "needs_improvements", "rejected":
		return task_target_for_role(state, "assignee")
	case "review", "needs_review":
		return task_target_for_role(state, "reviewer")
	case "blocked":
		return task_target_for_role(state, "coordinator")
	case "approved", "done":
		verifier := task_target_for_role(state, "verifier")
		if verifier != "" do return verifier
		return task_target_for_role(state, "coordinator")
	case:
		target := task_target_for_role(state, "assignee")
		if target != "" do return target
		return task_target_for_role(state, "coordinator")
	}
}

task_target_for_role :: proc(state: Task_State, role: string) -> string {
	switch role {
	case "assignee": if state.assignee_agent_instance_id != "" do return state.assignee_agent_instance_id
	case "reviewer": if state.reviewer_agent_instance_id != "" do return state.reviewer_agent_instance_id
	case "coordinator": if state.coordinator_agent_instance_id != "" do return state.coordinator_agent_instance_id
	case:
	}
	for i in 0..<task_participant_count {
		p := task_participants[i]
		if p.role != role do continue
		if p.task_id != state.task_id && (state.chain_id == "" || p.chain_id != state.chain_id) do continue
		return p.agent_instance_id
	}
	return ""
}

task_service_complete_chain :: proc(chain_id, final_summary, author_agent_instance_id: string) -> Task_Service_Result {
	if chain_id == "" || strings.trim_space(final_summary) == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"chain complete requires chain_id and non-empty summary"}`}
	return task_service_chain_status_command(Task_Chain_Status_Command{chain_id = chain_id, status = "completed", final_summary = final_summary, author_agent_instance_id = author_agent_instance_id})
}

task_service_set_chain_status :: proc(chain_id, status, final_summary, author_agent_instance_id: string) -> Task_Service_Result {
	return task_service_chain_status_command(Task_Chain_Status_Command{chain_id = chain_id, status = status, final_summary = final_summary, author_agent_instance_id = author_agent_instance_id})
}

task_service_chain_status_command :: proc(cmd: Task_Chain_Status_Command) -> Task_Service_Result {
	if cmd.chain_id == "" || cmd.status == "" do return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"chain status requires chain_id and status"}`}
	chain_idx, found := task_existing_chain_index(cmd.chain_id)
	if !found do return Task_Service_Result{ok = false, status_code = 404, message = `{"ok":false,"message":"chain not found"}`}
	stored_summary := task_chains[chain_idx].final_summary
	if (cmd.status == "done" || cmd.status == "archived" || cmd.status == "completed") && strings.trim_space(cmd.final_summary) == "" && stored_summary == "" {
		return Task_Service_Result{ok = false, status_code = 400, message = `{"ok":false,"message":"final_summary required"}`}
	}
	if cmd.final_summary != "" {
		summary_event := Task_Event{kind = .Chain_Final_Summary_Set, chain_id = cmd.chain_id, body = cmd.final_summary, author_agent_instance_id = cmd.author_agent_instance_id}
		task_store_append_event(summary_event)
		task_notify_event(summary_event)
	}
	kind := Task_Event_Kind.Chain_Status_Changed
	if cmd.status == "completed" || cmd.status == "done" do kind = .Chain_Completed
	body := cmd.final_summary
	status_event := Task_Event{kind = kind, chain_id = cmd.chain_id, status = cmd.status, body = body, author_agent_instance_id = cmd.author_agent_instance_id}
	if !task_store_append_event(status_event) do return Task_Service_Result{ok = false, status_code = 500, message = `{"ok":false,"message":"append chain status failed"}`}
	task_notify_event(status_event)
	archive_ok := true
	if cmd.status == "done" || cmd.status == "archived" || cmd.status == "completed" {
		archive_ok = task_archive_chain_to_hub(cmd.chain_id)
	}
	return Task_Service_Result{ok = true, status_code = 200, message = `{"ok":true,"archive_ok":true}` if archive_ok else `{"ok":true,"archive_ok":false,"archive_pending":true}`}
}

task_service_retry_pending_archives :: proc() -> Task_Service_Result {
	retried := task_store_retry_pending_archives()
	builder := strings.builder_make()
	strings.write_string(&builder, `{"ok":true,"retried":`)
	strings.write_string(&builder, fmt.tprintf("%d", retried))
	strings.write_string(&builder, `}`)
	return Task_Service_Result{ok = true, status_code = 200, message = strings.to_string(builder)}
}
