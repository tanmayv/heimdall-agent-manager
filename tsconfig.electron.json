{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "electron-dist",
    "rootDir": "src/ui/electron",
    "types": ["node"],
    "tsBuildInfoFile": "./tsconfig.electron.tsbuildinfo"
  },
  "include": ["src/ui/electron/**/*.cts"]
}
